# ── Shared (testnet defaults) ──

CKB_RPC_URL=https://testnet.ckb.dev/rpc
CKB_INDEXER_URL=https://testnet.ckb.dev/indexer
CORE_URL=http://localhost:8080
CORE_PORT=8080
MCP_PORT=8081

# Fiber Network
FIBER_RPC_URL=http://localhost:8227
FIBER_RPC_PORT=8227
FIBER_P2P_PORT=8228
FIBER_CURRENCY=Fibt
# FIBER_NODE_ID is written to .env.fiber by scripts/setup_fiber.sh
FIBER_NODE_ID=

# Spending limits (enforced on-chain by type script AND as a soft config in nerve-core).
DAILY_SPEND_LIMIT_CKB=100
PER_TX_LIMIT_CKB=20

# UTXOSwap API key (get from utxoswap.xyz)
UTXOSWAP_API_KEY=

# ── Private (your keys) ──

# LLM / OpenClaw (OpenAI-compatible)
# The bundled OpenClaw workspace is configured for https://share-ai.ckbdev.com.
# Bring your own API key and choose the model OpenClaw should use.
OPENAI_API_KEY=sk-...

# Signing backend configuration (loaded into Rust process, never exposed to the LLM).
# "local" (default): agent private key stored in AGENT_PRIVATE_KEY.
# "superise": delegate signing to SupeRISE wallet service.
# SIGNING_BACKEND=local

# For "local" mode: Testnet: generate with `openssl rand -hex 32`, fund from faucet.nervos.org.
# Mainnet: use a key that already controls funded CKB cells.
# Not required for "superise" mode.
AGENT_PRIVATE_KEY=0x...

# For "superise" mode: SupeRISE MCP endpoint URL (default: http://127.0.0.1:18799/mcp).
# SUPERISE_URL=http://127.0.0.1:18799/mcp

AGENT_IDENTITY_CELL=0x...:<index>

# Optional: pre-funded demo wallets (for nerve demo mode).
# Generate each with: openssl rand -hex 32
DEMO_POSTER_KEY=0x...
DEMO_WORKER_KEY=0x...

# Telegram bot integration.
# Create a bot via @BotFather on Telegram, then paste the token here.
OPENCLAW_TELEGRAM_TOKEN=
OPENCLAW_MODEL=gpt-5.4

# Admin API: only enable when deploying contracts via scripts/deploy_contracts.sh.
# ENABLE_ADMIN_API=1

# Sub-agent key store path (default: $HOME/.nerve/sub_agents.json).
# SUB_AGENT_STORE_PATH=$HOME/.nerve/sub_agents.json

# ── Deployed (from /join or deploy script → .env.deployed) ──

AGENT_IDENTITY_TYPE_CODE_HASH=0x...
AGENT_IDENTITY_DEP_TX_HASH=0x...
JOB_CELL_TYPE_CODE_HASH=0x...
JOB_CELL_DEP_TX_HASH=0x...
CAP_NFT_TYPE_CODE_HASH=0x...
CAP_NFT_DEP_TX_HASH=0x...
REPUTATION_TYPE_CODE_HASH=0x...
REPUTATION_DEP_TX_HASH=0x...
DOB_BADGE_CODE_HASH=0x...
DOB_BADGE_DEP_TX_HASH=0x...
