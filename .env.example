# LLM
ANTHROPIC_API_KEY=sk-ant-...
# If using a shared proxy (e.g. hackathon), set the base URL:
# ANTHROPIC_BASE_URL=https://share-ai.ckbdev.com

# CKB Testnet
CKB_RPC_URL=https://testnet.ckb.dev/rpc
CKB_INDEXER_URL=https://testnet.ckb.dev/indexer

# Fiber Network
FIBER_RPC_URL=http://localhost:8227
FIBER_RPC_PORT=8227
FIBER_P2P_PORT=8228
FIBER_CURRENCY=Fibt
# FIBER_NODE_ID is written to .env.fiber by scripts/setup_fiber.sh
FIBER_NODE_ID=

# Agent config (loaded into Rust process — never exposed to OpenClaw/LLM).
# Generate a key: openssl rand -hex 32
AGENT_PRIVATE_KEY=0x...
AGENT_IDENTITY_CELL=0x...:<index>

# Deployed contract addresses (written by scripts/deploy_contracts.sh → .env.deployed)
AGENT_IDENTITY_TYPE_CODE_HASH=0x...
AGENT_IDENTITY_DEP_TX_HASH=0x...
JOB_CELL_TYPE_CODE_HASH=0x...
JOB_CELL_DEP_TX_HASH=0x...
CAP_NFT_TYPE_CODE_HASH=0x...
CAP_NFT_DEP_TX_HASH=0x...
REPUTATION_TYPE_CODE_HASH=0x...
REPUTATION_DEP_TX_HASH=0x...
MOCK_AMM_TYPE_CODE_HASH=0x...
MOCK_AMM_DEP_TX_HASH=0x...
DOB_BADGE_CODE_HASH=0x...
DOB_BADGE_DEP_TX_HASH=0x...

# nerve-core base URL (used by nerve-mcp bridge)
CORE_URL=http://localhost:8080

# Spending limits (enforced on-chain by type script AND as a soft config in nerve-core).
DAILY_SPEND_LIMIT_CKB=100
PER_TX_LIMIT_CKB=20

# Optional: pre-funded demo wallets (for nerve demo mode).
# Generate each with: openssl rand -hex 32
DEMO_POSTER_KEY=0x...
DEMO_WORKER_KEY=0x...

# OpenClaw — Telegram bot integration.
# Create a bot via @BotFather on Telegram, then paste the token here.
OPENCLAW_TELEGRAM_TOKEN=
OPENCLAW_MODEL=claude-opus-4-6

# Admin API — only enable when deploying contracts via scripts/deploy_contracts.sh.
# ENABLE_ADMIN_API=1

# Service ports
CORE_PORT=8080
MCP_PORT=8081
