# LLM
ANTHROPIC_API_KEY=sk-ant-...

# CKB Testnet
CKB_RPC_URL=https://testnet.ckb.dev/rpc
CKB_INDEXER_URL=https://testnet.ckb.dev/indexer

# Fiber Network
FIBER_NODE_URL=http://localhost:8228
FIBER_RPC_PORT=8227

# Agent config (loaded into Rust process — never exposed to OpenClaw/LLM)
AGENT_PRIVATE_KEY=0x...
AGENT_IDENTITY_CELL=0x...:<index>

# Spending limits (enforced on-chain by lock script AND as a soft config)
DAILY_SPEND_LIMIT_CKB=100
PER_TX_LIMIT_CKB=20

# Optional: pre-funded demo wallets (for nerve demo mode)
DEMO_POSTER_KEY=0x...
DEMO_WORKER_KEY=0x...

# OpenClaw
OPENCLAW_TELEGRAM_TOKEN=...
OPENCLAW_MODEL=claude-opus-4-6

# Service ports
CORE_PORT=8080
MCP_PORT=8081
