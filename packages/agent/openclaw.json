{
	"agents": {
		"defaults": {
			"model": "claude-opus-4-6"
		}
	},
	"providers": {
		"anthropic": {
			"apiKey": "${ANTHROPIC_API_KEY}"
		}
	},
	"channels": {
		"telegram": {
			"token": "${OPENCLAW_TELEGRAM_TOKEN}",
			"agentName": "NERVE"
		}
	},
	"skills": {
		"entries": [
			"./skills/supervisor",
			"./skills/marketplace-worker",
			"./skills/payment-worker",
			"./skills/defi-worker",
			"./skills/chain-scanner",
			"./skills/autonomous-worker"
		]
	},
	"crons": {
		"job-scanner": {
			"schedule": "*/10 * * * *",
			"agent": "nerve",
			"task": "Run heartbeat job scan"
		},
		"auto-worker": {
			"schedule": "*/5 * * * *",
			"agent": "nerve",
			"task": "Run autonomous worker loop using the autonomous-worker skill"
		}
	}
}
