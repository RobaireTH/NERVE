      "width": 2402.40883258628,
      "height": 194.01025398618899,
      "text": "4. Job Lifecycle on CKB",
      "fontSize": 155.2082031889512,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 32,
      "containerId": null,
      "originalText": "4. Job Lifecycle on CKB",
      "lineHeight": 1.25,
      "autoResize": false,
      "index": "aA"
    },
    {
      "id": "nerve-c",
      "type": "text",
      "x": -4759.108194455048,
      "y": 1923.4308944820305,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1143541049,
      "version": 385,
      "versionNonce": 1231989633,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774354846844,
      "link": null,
      "locked": false,
      "width": 1956.3775329008804,
      "height": 2304.4460294093474,
      "text": "State machine\nOpen -> Reserved -> Claimed -> Completed\nOpen/Reserved -> Cancel / Expire\n\nOpen -> Reserved\n- input: live job cell\n- signer: poster\n- worker lock set\n- capability checks if required\n\nReserved -> Claimed\n- signer: poster\n- poster lock controls job cell\n\nClaimed -> Completed\n- signer: poster\n- worker_lock_args included\n- result text / witness proof\n- reward routed on-chain\n- result memo possible\n- optional Fiber follow-up in MCP\n\nImmutable fields:\nposter, reward, ttl, capability_hash, description_hash\nMinimum reward enforced at post time: 61 CKB",
      "fontSize": 73.74227294109913,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 21,
      "containerId": null,
      "originalText": "State machine\nOpen -> Reserved -> Claimed -> Completed\nOpen/Reserved -> Cancel / Expire\n\nOpen -> Reserved\n- input: live job cell\n- signer: poster\n- worker lock set\n- capability checks if required\n\nReserved -> Claimed\n- signer: poster\n- poster lock controls job cell\n\nClaimed -> Completed\n- signer: poster\n- worker_lock_args included\n- result text / witness proof\n- reward routed on-chain\n- result memo possible\n- optional Fiber follow-up in MCP\n\nImmutable fields:\nposter, reward, ttl, capability_hash, description_hash\nMinimum reward enforced at post time: 61 CKB",
      "lineHeight": 1.25,
      "autoResize": true,
      "index": "aB"
    },
