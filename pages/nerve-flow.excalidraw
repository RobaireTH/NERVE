      "width": 1939.9998949362632,
      "height": 197.11228879031555,
      "text": "2. User Journey: Poster",
      "fontSize": 145.24063384549564,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 32,
      "containerId": null,
      "originalText": "2. User Journey: Poster",
      "lineHeight": 1.25,
      "autoResize": true,
      "index": "a4"
    },
    {
      "id": "nerve-6",
      "type": "text",
      "x": -1124.0177548782044,
      "y": -1002.9386022524523,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 2107867982,
      "version": 613,
      "versionNonce": 1620938817,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774354846844,
      "link": null,
      "locked": false,
      "width": 3522.2599671242883,
      "height": 2285.1666381795817,
      "text": "Join / Setup\n1 fund wallet\n2 start services\n3 spawn identity\n4 create reputation\n5 optional Fiber node\n6 optional channels\n\nPost Job\n1 choose reward / ttl / capability / description / optional payment metadata\n2 POST /jobs\n3 nerve-core builds tx\n4 CKB creates Job Cell -> Open\n\nManage Job\n- monitor Open / Reserved / Claimed / Completed\n- complete with result verification\n- badge + reputation\n- optional direct Fiber or hold settlement\n\nConstraints:\n- minimum reward 61 CKB\n- claim + completion signed by poster",
      "fontSize": 79.48405698015934,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 21,
      "containerId": null,
      "originalText": "Join / Setup\n1 fund wallet\n2 start services\n3 spawn identity\n4 create reputation\n5 optional Fiber node\n6 optional channels\n\nPost Job\n1 choose reward / ttl / capability / description / optional payment metadata\n2 POST /jobs\n3 nerve-core builds tx\n4 CKB creates Job Cell -> Open\n\nManage Job\n- monitor Open / Reserved / Claimed / Completed\n- complete with result verification\n- badge + reputation\n- optional direct Fiber or hold settlement\n\nConstraints:\n- minimum reward 61 CKB\n- claim + completion signed by poster",
      "lineHeight": 1.25,
      "autoResize": false,
      "index": "a5"
