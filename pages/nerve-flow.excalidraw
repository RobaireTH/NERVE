    },
    {
      "id": "nerve-3",
      "type": "text",
      "x": -4820.389664209197,
      "y": -855.9603543466421,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1694225917,
      "version": 433,
      "versionNonce": 172079265,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774354846844,
      "link": null,
      "locked": false,
      "width": 2501.80563040735,
      "height": 1283.8234598842919,
      "text": "[VERIFIED][ON-CHAIN][OFF-CHAIN]\nPoster -> OpenClaw -> nerve-mcp -> nerve-core -> CKB\nWorker Agent / External Agent -> nerve-mcp\nnerve-mcp -> CKB RPC+Indexer\nnerve-mcp -> Poster Fiber Node\nnerve-mcp -> Worker Fiber Node\nExplorer -> CKB + Fiber visibility\nNotes:\n- nerve-core = build + sign + broadcast\n- nerve-mcp = reads + orchestration + Fiber helpers\n- CKB = source of truth",
      "fontSize": 93.36897890067577,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 21,
      "containerId": null,
      "originalText": "[VERIFIED][ON-CHAIN][OFF-CHAIN]\nPoster -> OpenClaw -> nerve-mcp -> nerve-core -> CKB\nWorker Agent / External Agent -> nerve-mcp\nnerve-mcp -> CKB RPC+Indexer\nnerve-mcp -> Poster Fiber Node\nnerve-mcp -> Worker Fiber Node\nExplorer -> CKB + Fiber visibility\nNotes:\n- nerve-core = build + sign + broadcast\n- nerve-mcp = reads + orchestration + Fiber helpers\n- CKB = source of truth",
      "lineHeight": 1.25,
      "autoResize": true,
      "index": "a2"
