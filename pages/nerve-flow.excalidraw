    {
      "id": "nerve-x",
      "type": "text",
      "x": 4326.708084949887,
      "y": 5883.993136028021,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 244541412,
      "version": 511,
      "versionNonce": 317454561,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774354846844,
      "link": null,
      "locked": false,
      "width": 3201.899097978964,
      "height": 860.6237958282225,
      "text": "Failure paths\n- stale rep outpoint -> cell_not_found -> fetch current rep outpoint\n- reward below 61 CKB -> reject at post time\n- no Fiber route -> connect peer / open channel / retry\n- hold invoice reuse -> use fresh preimage + payment_hash\n- missing Fiber mapping -> register lock_args -> node_id (+ rpc_url)\n- announcement configured but not reachable -> public TCP reachability still required\n- explorer still unannounced -> propagation / reachability issue",
      "fontSize": 76.49989296250867,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 21,
      "containerId": null,
      "originalText": "Failure paths\n- stale rep outpoint -> cell_not_found -> fetch current rep outpoint\n- reward below 61 CKB -> reject at post time\n- no Fiber route -> connect peer / open channel / retry\n- hold invoice reuse -> use fresh preimage + payment_hash\n- missing Fiber mapping -> register lock_args -> node_id (+ rpc_url)\n- announcement configured but not reachable -> public TCP reachability still required\n- explorer still unannounced -> propagation / reachability issue",
      "lineHeight": 1.25,
      "autoResize": true,
      "index": "aW"
    },
