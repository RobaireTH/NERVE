    },
    {
      "id": "nerve-l",
      "type": "text",
      "x": -853.9436571993529,
      "y": 4330.540013684402,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 412626985,
      "version": 255,
      "versionNonce": 2081251937,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774354846844,
      "link": null,
      "locked": false,
      "width": 2553.8464670838785,
      "height": 1016.3330647004227,
      "text": "[VERIFIED][LOCAL DEMO][OFF-CHAIN]\nFlow\n1 worker Fiber node running\n2 lock_args -> node_id (+ rpc_url) mapping exists\n3 poster calls /fiber/pay or /fiber/pay-agent\n4 if route exists, pay directly\n5 if route missing, MCP may connect peer / open channel / accept channel / wait ready / retry\n6 payment status -> Success\n\nVerified paths:\n- direct invoice payment: VERIFIED\n- pay-agent: VERIFIED\n\nCaveat:\nroute + liquidity still determine success",
      "fontSize": 54.20443011735588,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 21,
      "containerId": null,
      "originalText": "[VERIFIED][LOCAL DEMO][OFF-CHAIN]\nFlow\n1 worker Fiber node running\n2 lock_args -> node_id (+ rpc_url) mapping exists\n3 poster calls /fiber/pay or /fiber/pay-agent\n4 if route exists, pay directly\n5 if route missing, MCP may connect peer / open channel / accept channel / wait ready / retry\n6 payment status -> Success\n\nVerified paths:\n- direct invoice payment: VERIFIED\n- pay-agent: VERIFIED\n\nCaveat:\nroute + liquidity still determine success",
      "lineHeight": 1.25,
      "autoResize": true,
