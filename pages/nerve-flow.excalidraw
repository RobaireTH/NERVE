    {
      "id": "nerve-o",
      "type": "text",
      "x": 2218.311124092086,
      "y": 4313.961235115607,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1010483750,
      "version": 379,
      "versionNonce": 455905793,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774354846844,
      "link": null,
      "locked": false,
      "width": 1454.415874529088,
      "height": 1290.3428026902363,
      "text": "[IMPLEMENTED][LIVE TESTED][ON-CHAIN+OFF-CHAIN]\nA Job post\n- payment.mode = fiber\n- invoice_mode = hold\n- lock_args / node_id / rpc_url / amount_ckb\n- payment_hash or preimage\n- if only preimage exists, payment_hash = sha256(preimage)\n\nB Escrow setup\n- POST /jobs/:tx_hash/:index/escrow\n- create worker-side hold invoice\n- poster pays hold invoice\n- funds are locked off-chain\n\nC Completion\n- worker completes on-chain\n- MCP checks preimage matches payment_hash\n\nD Settlement\n- settle hold invoice\n- worker receives off-chain payment",
      "fontSize": 49.15591629296138,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 21,
      "containerId": null,
      "originalText": "[IMPLEMENTED][LIVE TESTED][ON-CHAIN+OFF-CHAIN]\nA Job post\n- payment.mode = fiber\n- invoice_mode = hold\n- lock_args / node_id / rpc_url / amount_ckb\n- payment_hash or preimage\n- if only preimage exists, payment_hash = sha256(preimage)\n\nB Escrow setup\n- POST /jobs/:tx_hash/:index/escrow\n- create worker-side hold invoice\n- poster pays hold invoice\n- funds are locked off-chain\n\nC Completion\n- worker completes on-chain\n- MCP checks preimage matches payment_hash\n\nD Settlement\n- settle hold invoice\n- worker receives off-chain payment",
      "lineHeight": 1.25,
      "autoResize": true,
      "index": "aN"
